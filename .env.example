# Runtime knobs — copy to .env and adjust
# Configuration priority: CLI flags > .env > config.json

# DeepSeek API key — enables LLM-powered answers for free-text essay questions.
# If unset, essay fields get a generic fallback answer. Get a key at https://platform.deepseek.com/
API_KEY=

MAX_APPLICATIONS=10
HEADLESS=false
DRY_RUN=false
PLATFORMS=linkedin
LOG_LEVEL=info
DELAY_MIN_BETWEEN_APPS=5000
DELAY_MAX_BETWEEN_APPS=15000
SCREENSHOT_ON_ERROR=true
MAX_PAGES=5
